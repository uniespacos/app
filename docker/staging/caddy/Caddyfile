# Global options
{
    auto_https off
}
:80 {
    root * /var/www/public
    file_server
    
    # Enable robust logging for debugging
    log {
        output stdout
        format json
    }

    # Proxy to PHP-FPM
    php_fastcgi app:9000 {
        # Ensure we pass the correct protocol to Laravel
        env HTTPS on
    }

    # Reverb WebSockets
    handle /app/* {
        reverse_proxy reverb:9000 {
            header_up Host {http.request.host}
            header_up X-Forwarded-For {http.request.remote}
            header_up X-Forwarded-Proto {http.request.scheme}
        }
    }
}
