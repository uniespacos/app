# Global options
{
    auto_https off
}

:80 {
    root * /var/www/public
    file_server
    
    # Enable robust logging for debugging
    log {
        output stdout
        format json
    }

    # Proxy to PHP-FPM
    php_fastcgi app:9000 {
        # Force HTTPS on for PHP-FPM since we are always behind a secure proxy (Cloudflare)
        # This is the most reliable way to ensure Laravel correctly validates URL signatures.
        env HTTPS on
    }

    # Reverb WebSockets
    handle /app/* {
        reverse_proxy reverb:9000 {
            header_up Host {http.request.host}
            header_up X-Forwarded-For {http.request.remote}
            header_up X-Forwarded-Proto https
        }
    }
}
